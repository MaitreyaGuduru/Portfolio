# Local/default values for build-time configuration.
#
# Every var here is NEXT_PUBLIC_* because this site is a static export
# (output: "export") — there's no server at runtime, so anything the app
# needs gets inlined into the client bundle at build time. That also means
# none of these are actually secret; they end up in the shipped HTML/JS
# regardless of where you store them.
#
# In GitHub Actions, these are set from repository Variables (Settings →
# Secrets and variables → Actions → Variables) and passed to the build step
# in .github/workflows/nextjs.yml, overriding the values below.

NEXT_PUBLIC_SITE_NAME="Maitreya Guduru"
NEXT_PUBLIC_SITE_ROLE="Software Engineer"
NEXT_PUBLIC_SITE_TAGLINE="Building scalable backend systems and AI-powered products."
# GitHub Pages project-site URL. Swap this if a custom domain is added later.
NEXT_PUBLIC_SITE_URL="https://maitreyaguduru.github.io/Portfolio"
NEXT_PUBLIC_SITE_EMAIL="gudurumaitreya@gmail.com"
NEXT_PUBLIC_SITE_GITHUB="https://github.com/maitreyaguduru"
NEXT_PUBLIC_SITE_LINKEDIN="https://www.linkedin.com/in/maitreya-guduru-25468522b/"
NEXT_PUBLIC_SITE_LOCATION="India"
NEXT_PUBLIC_SITE_AVAILABILITY="Open to connections"

# GitHub Pages serves this project site under /Portfolio, not the domain
# root. Left empty here so local dev/build runs at the domain root; the
# workflow overrides this to "/Portfolio" for the deployed build.
NEXT_PUBLIC_BASE_PATH=
